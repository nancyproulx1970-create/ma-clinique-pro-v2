# ============================================================
# Ma Clinique Pro V2 — Variables d'environnement
# ============================================================
# Copier ce fichier en .env.local et remplir les valeurs.
# Ne JAMAIS committer .env.local — il est protégé par .gitignore.
# ============================================================

# --- Supabase ---
# Disponible dans : Supabase Dashboard → Settings → API
SUPABASE_URL=https://anzgkxmxkcetzbtjttuh.supabase.co
SUPABASE_ANON_KEY=                    # clé publique (safe côté client)
SUPABASE_SERVICE_ROLE_KEY=            # clé privée — serveur uniquement, jamais client

# --- OpenAI ---
# Utilisée UNIQUEMENT par l'Edge Function generate-note (côté serveur)
# Ne pas exposer dans FlutterFlow ou tout autre client
OPENAI_API_KEY=sk-...

# --- Google Maps ---
# Utilisée pour l'optimisation de tournée (Phase 3)
GOOGLE_MAPS_API_KEY=

# --- Firebase (héritage — à supprimer après migration complète) ---
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# --- GitHub Actions (CI/CD) ---
# Ajouter ces secrets dans : GitHub → Settings → Secrets → Actions
# SUPABASE_ACCESS_TOKEN    → supabase.com → Account → Access Tokens
# SUPABASE_DB_PASSWORD     → mot de passe de la base Supabase
# (Les autres variables ci-dessus sont aussi des secrets GitHub Actions)
